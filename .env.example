# ─── backup.sh ─── Configuración vía .env ─────────────────
# Copia este fichero como .env y rellena tus valores.
# Las variables sin valor se ignoran.

# === Globales ===
PCLOUD_REMOTE=pcloud
PCLOUD_PATH=backups
RETENTION_DAYS=30
# Déjalo vacío para que GPG pida la contraseña en cada ejecución
GPG_PASSPHRASE=

# === Backup de carpetas (FOLDER_BACKUP_<N>_*) ===
# Indiza desde 1, sin huecos. Para añadir más, copia el bloque con N+1.

FOLDER_BACKUP_1_NAME=immich-photos
FOLDER_BACKUP_1_PATH=/home/ismael/immich/data

# FOLDER_BACKUP_2_NAME=nextcloud-data
# FOLDER_BACKUP_2_PATH=/home/ismael/nextcloud/data

# === Backup de PostgreSQL (DB_BACKUP_<N>_*) ===
# TYPE = "docker" (el contenedor está en la misma máquina)
#      = "network" (acceso por TCP/IP, ej: Synology)

DB_BACKUP_1_NAME=immich-db
DB_BACKUP_1_HOST=immich-database
DB_BACKUP_1_PORT=5432
DB_BACKUP_1_USER=${IMMICH_DB_USERNAME}
DB_BACKUP_1_PASS=${IMMICH_DB_PASSWORD}
DB_BACKUP_1_DATABASE=${IMMICH_DB_DATABASE_NAME}
DB_BACKUP_1_TYPE=docker

# DB_BACKUP_2_NAME=synology-app
# DB_BACKUP_2_HOST=192.168.1.100
# DB_BACKUP_2_PORT=5432
# DB_BACKUP_2_USER=app_user
# DB_BACKUP_2_PASS=app_password
# DB_BACKUP_2_DATABASE=app_db
# DB_BACKUP_2_TYPE=network
